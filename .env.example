PORT=3000
DATABASE_URL=postgres://app_user:Micro%402026@localhost:5432/wa_bank_monitor
# Local Postgres usually uses false. Render/hosted Postgres usually requires true.
DB_SSL=false
# Windows local example:
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Render example, if tesseract is installed in PATH:
# TESSERACT_PATH=tesseract
# Optional. When set, /api requests must include HMAC signature headers from trusted apps/services.
API_REQUEST_SECRET=
# Optional WhatsApp Web listener. Read-only capture; enable after accounts are added.
BAILEYS_ENABLED=true
BAILEYS_AUTH_DIR=baileys-auth
# Admin dashboard login. Use a strong password and session secret in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Optional TOTP base32 secret for authenticator apps. Leave empty to disable TOTP.
ADMIN_TOTP_SECRET=
